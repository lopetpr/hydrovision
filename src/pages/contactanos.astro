---
import Layout from "../layouts/Layout.astro";
import ScrollReveal from "@/components/ScrollReveal.astro";
---

<Layout
  title="Contáctanos | HYDROVISION"
  description="Contáctanos para solicitar un diagnóstico hídrico gratuito, cotizar un kit de agua o explorar alianzas estratégicas para llevar agua segura a más comunidades altoandinas."
>
  <main class="w-full bg-white">

    <!-- Hero -->
    <section class="relative py-20 sm:py-28 lg:py-36 bg-gray-900 text-white overflow-hidden">
      <!-- Glow decorativo -->
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-cyan-500/10 rounded-full -translate-y-1/2 translate-x-1/3 blur-3xl pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-blue-600/10 rounded-full translate-y-1/2 -translate-x-1/3 blur-3xl pointer-events-none"></div>
      <!-- Grid pattern sutil -->
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 40px 40px;"
      ></div>

      <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <ScrollReveal delay={100} animation="fade-up" intensity="low">
          <span class="inline-block text-cyan-400 font-medium tracking-widest uppercase text-xs sm:text-sm mb-6 border border-cyan-400/30 px-4 py-1.5 rounded-full">
            Hablemos
          </span>
        </ScrollReveal>

        <ScrollReveal delay={200} animation="fade-up" intensity="high">
          <h1 class="text-3xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-tight mb-6 sm:mb-8">
            Llevemos agua segura
            <span class="block bg-gradient-to-r from-cyan-400 to-blue-400 bg-clip-text text-transparent">
              a más comunidades
            </span>
          </h1>
        </ScrollReveal>

        <ScrollReveal delay={300} animation="fade-up" intensity="medium">
          <p class="text-base sm:text-lg lg:text-xl text-gray-400 mb-10 sm:mb-14 max-w-2xl mx-auto leading-relaxed">
            Buscamos proyectos, alianzas y financiamiento para ampliar el impacto de HYDROVISION en el altiplano peruano.
          </p>
        </ScrollReveal>

        <ScrollReveal delay={400} animation="fade-up" intensity="low">
          <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
            <a
              href="https://wa.me/51915030965"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-[#25D366] text-white font-semibold px-6 sm:px-8 py-3 sm:py-4 rounded-full hover:bg-[#1fb855] transition-all hover:scale-105 text-sm sm:text-base shadow-lg shadow-green-900/30"
            >
              <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <span>WhatsApp directo</span>
            </a>
            <a
              href="#formulario"
              class="inline-flex items-center justify-center gap-2 bg-cyan-500 text-white font-semibold px-6 sm:px-8 py-3 sm:py-4 rounded-full hover:bg-cyan-400 transition-all hover:scale-105 text-sm sm:text-base shadow-lg shadow-cyan-900/30"
            >
              <span>Solicitar diagnóstico</span>
            </a>
            <a
              href="#aliado"
              class="inline-flex items-center justify-center gap-2 border border-white/20 text-white font-semibold px-6 sm:px-8 py-3 sm:py-4 rounded-full hover:bg-white/10 transition-all text-sm sm:text-base"
            >
              <span>Ser aliado</span>
            </a>
          </div>
        </ScrollReveal>
      </div>
    </section>

    <!-- Cards de contacto rápido -->
    <section class="py-12 sm:py-16 bg-white">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">

          <ScrollReveal delay={100} animation="fade-up" intensity="medium">
            <a
              href="https://wa.me/51915030965"
              target="_blank"
              rel="noopener noreferrer"
              class="group flex flex-col items-center text-center p-6 sm:p-8 rounded-2xl border border-gray-100 hover:border-green-200 hover:bg-green-50/50 transition-all duration-300 hover:shadow-xl hover:shadow-green-100/80"
            >
              <div class="w-14 h-14 rounded-2xl bg-green-100 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
                <svg class="w-7 h-7 text-green-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">WhatsApp</p>
              <p class="font-bold text-gray-900">+51 915 030 965</p>
              <p class="text-xs text-green-600 font-semibold mt-2 group-hover:underline">Respuesta inmediata →</p>
            </a>
          </ScrollReveal>

          <ScrollReveal delay={200} animation="fade-up" intensity="medium">
            <a
              href="mailto:hydrovision@gmail.com"
              class="group flex flex-col items-center text-center p-6 sm:p-8 rounded-2xl border border-gray-100 hover:border-cyan-200 hover:bg-cyan-50/50 transition-all duration-300 hover:shadow-xl hover:shadow-cyan-100/80"
            >
              <div class="w-14 h-14 rounded-2xl bg-cyan-100 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
                <svg class="w-7 h-7 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Email</p>
              <p class="font-bold text-gray-900">hydrovision@gmail.com</p>
              <p class="text-xs text-cyan-600 font-semibold mt-2 group-hover:underline">Enviar correo →</p>
            </a>
          </ScrollReveal>

          <ScrollReveal delay={300} animation="fade-up" intensity="medium">
            <div class="flex flex-col items-center text-center p-6 sm:p-8 rounded-2xl border border-gray-100 bg-gray-50/50">
              <div class="w-14 h-14 rounded-2xl bg-blue-100 flex items-center justify-center mb-4">
                <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Ubicación</p>
              <p class="font-bold text-gray-900">Macusani, Puno</p>
              <p class="text-xs text-gray-500 mt-2">Carabaya — Perú</p>
            </div>
          </ScrollReveal>

        </div>
      </div>
    </section>

    <!-- Formulario -->
    <section id="formulario" class="py-16 sm:py-20 lg:py-28 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-start">

          <!-- Info lateral -->
          <div class="lg:pt-2">
            <ScrollReveal delay={100} animation="fade-right" intensity="medium">
              <span class="text-7xl sm:text-8xl lg:text-9xl font-black text-gray-200 leading-none select-none block mb-4">01</span>
              <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-4">
                Cuéntanos tu proyecto
              </h2>
              <p class="text-base sm:text-lg text-gray-500 mb-10 leading-relaxed">
                Cuéntanos sobre tu comunidad o proyecto. Respondemos en menos de 24 horas con una propuesta adaptada a tu territorio.
              </p>
            </ScrollReveal>

            <ScrollReveal delay={200} animation="fade-right" intensity="low">
              <div class="space-y-4">
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-full bg-cyan-100 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                    </svg>
                  </div>
                  <p class="text-gray-700 font-medium">Diagnóstico inicial gratuito</p>
                </div>
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-full bg-cyan-100 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                    </svg>
                  </div>
                  <p class="text-gray-700 font-medium">Respuesta en menos de 24 h</p>
                </div>
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-full bg-cyan-100 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                    </svg>
                  </div>
                  <p class="text-gray-700 font-medium">Soluciones adaptadas a tu terreno</p>
                </div>
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-full bg-cyan-100 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                    </svg>
                  </div>
                  <p class="text-gray-700 font-medium">Sin compromisos, sin costo inicial</p>
                </div>
              </div>
            </ScrollReveal>

            <!-- Testimonial rápido -->
            <ScrollReveal delay={300} animation="fade-right" intensity="low">
              <div class="mt-10 p-6 rounded-2xl bg-white border border-gray-100 shadow-sm">
                <p class="text-gray-600 text-sm leading-relaxed italic mb-4">
                  "El diagnóstico con drones nos permitió identificar fuentes de agua que desconocíamos. Excelente trabajo profesional."
                </p>
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-full bg-cyan-600 flex items-center justify-center text-white font-bold text-sm flex-shrink-0">P</div>
                  <div>
                    <p class="font-semibold text-gray-900 text-sm">Pedro Quispe</p>
                    <p class="text-gray-400 text-xs">Alcalde, Municipio de Tapara</p>
                  </div>
                </div>
              </div>
            </ScrollReveal>
          </div>

          <!-- Formulario -->
          <ScrollReveal delay={150} animation="fade-left" intensity="medium">
            <div class="bg-white rounded-3xl shadow-xl shadow-gray-200/80 p-6 sm:p-8 lg:p-10 border border-gray-100">
              <h3 class="text-lg font-bold text-gray-900 mb-6">Envíanos tu consulta</h3>
              <form class="space-y-5" action="#" method="POST">

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="nombre" class="block text-sm font-semibold text-gray-700 mb-1.5">Nombre completo</label>
                    <input
                      type="text" id="nombre" name="nombre" required placeholder="Tu nombre"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20 outline-none transition-all bg-gray-50 focus:bg-white text-sm"
                    />
                  </div>
                  <div>
                    <label for="telefono" class="block text-sm font-semibold text-gray-700 mb-1.5">WhatsApp</label>
                    <input
                      type="tel" id="telefono" name="telefono" placeholder="+51 999 999 999"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20 outline-none transition-all bg-gray-50 focus:bg-white text-sm"
                    />
                  </div>
                </div>

                <div>
                  <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Correo electrónico</label>
                  <input
                    type="email" id="email" name="email" required placeholder="tu@email.com"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20 outline-none transition-all bg-gray-50 focus:bg-white text-sm"
                  />
                </div>

                <div>
                  <label for="tipo" class="block text-sm font-semibold text-gray-700 mb-1.5">¿Qué te interesa?</label>
                  <select
                    id="tipo" name="tipo" required
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20 outline-none transition-all bg-gray-50 focus:bg-white appearance-none text-sm"
                  >
                    <option value="">Selecciona una opción</option>
                    <option value="diagnostico">Solicitar diagnóstico hídrico</option>
                    <option value="kit-consumo">Cotizar Kit Consumo Humano</option>
                    <option value="kit-geotanque">Cotizar Kit Geotanque</option>
                    <option value="alianza">Ser aliado estratégico</option>
                    <option value="proyecto">Proponer un proyecto</option>
                    <option value="otro">Otro</option>
                  </select>
                </div>

                <div>
                  <label for="organizacion" class="block text-sm font-semibold text-gray-700 mb-1.5">Comunidad u organización</label>
                  <input
                    type="text" id="organizacion" name="organizacion" placeholder="Nombre de tu comunidad u organización"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20 outline-none transition-all bg-gray-50 focus:bg-white text-sm"
                  />
                </div>

                <div>
                  <label for="mensaje" class="block text-sm font-semibold text-gray-700 mb-1.5">Mensaje</label>
                  <textarea
                    id="mensaje" name="mensaje" rows="4" required
                    placeholder="Cuéntanos sobre tu proyecto o necesidad..."
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20 outline-none transition-all bg-gray-50 focus:bg-white resize-none text-sm"
                  ></textarea>
                </div>

                <button
                  type="submit"
                  class="w-full bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-600 hover:to-blue-700 text-white font-bold px-8 py-4 rounded-full transition-all hover:scale-[1.02] shadow-lg shadow-cyan-500/25 flex items-center justify-center gap-3 text-sm sm:text-base"
                >
                  <span>Enviar mensaje</span>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </button>

                <p class="text-xs text-center text-gray-400">
                  ¿Prefieres algo más rápido? Escríbenos por
                  <a href="https://wa.me/51915030965" target="_blank" rel="noopener noreferrer" class="text-green-600 hover:underline font-semibold">WhatsApp</a>
                </p>
              </form>
            </div>
          </ScrollReveal>

        </div>
      </div>
    </section>

    <!-- Aliados -->
    <section id="aliado" class="py-16 sm:py-20 lg:py-28 bg-white">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

        <ScrollReveal delay={100} animation="fade-up" intensity="medium">
          <div class="text-center mb-12 sm:mb-16">
            <p class="text-cyan-600 font-medium mb-4 tracking-wide uppercase text-xs sm:text-sm">Alianzas</p>
            <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4">
              ¿Quieres ser aliado estratégico?
            </h2>
            <p class="text-base sm:text-lg text-gray-500 max-w-2xl mx-auto">
              ONGs, empresas, municipalidades y organizaciones pueden sumarse para llevar agua segura a más comunidades altoandinas.
            </p>
          </div>
        </ScrollReveal>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-6">
          <ScrollReveal delay={100} animation="fade-up" intensity="medium">
            <div class="group p-6 sm:p-8 rounded-2xl border border-gray-100 hover:border-cyan-200 hover:bg-cyan-50/30 transition-all duration-300 hover:shadow-xl hover:shadow-cyan-100/60">
              <div class="w-12 h-12 rounded-xl bg-cyan-100 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300">
                <span class="text-2xl" aria-hidden="true">🏛️</span>
              </div>
              <h3 class="font-bold text-gray-900 mb-2 text-lg">Municipalidades</h3>
              <p class="text-gray-500 text-sm leading-relaxed">Proyectos de agua para comunidades rurales con diagnóstico técnico moderno.</p>
            </div>
          </ScrollReveal>

          <ScrollReveal delay={200} animation="fade-up" intensity="medium">
            <div class="group p-6 sm:p-8 rounded-2xl border border-gray-100 hover:border-cyan-200 hover:bg-cyan-50/30 transition-all duration-300 hover:shadow-xl hover:shadow-cyan-100/60">
              <div class="w-12 h-12 rounded-xl bg-cyan-100 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300">
                <span class="text-2xl" aria-hidden="true">🌍</span>
              </div>
              <h3 class="font-bold text-gray-900 mb-2 text-lg">ONGs</h3>
              <p class="text-gray-500 text-sm leading-relaxed">Alianzas para desarrollo rural sostenible con impacto medible en el altiplano.</p>
            </div>
          </ScrollReveal>

          <ScrollReveal delay={300} animation="fade-up" intensity="medium">
            <div class="group p-6 sm:p-8 rounded-2xl border border-gray-100 hover:border-cyan-200 hover:bg-cyan-50/30 transition-all duration-300 hover:shadow-xl hover:shadow-cyan-100/60">
              <div class="w-12 h-12 rounded-xl bg-cyan-100 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform duration-300">
                <span class="text-2xl" aria-hidden="true">🏢</span>
              </div>
              <h3 class="font-bold text-gray-900 mb-2 text-lg">Empresas</h3>
              <p class="text-gray-500 text-sm leading-relaxed">Responsabilidad social con impacto real y documentado en comunidades peruanas.</p>
            </div>
          </ScrollReveal>
        </div>

        <ScrollReveal delay={200} animation="fade-up" intensity="low">
          <div class="mt-12 text-center">
            <a
              href="mailto:hydrovision@gmail.com?subject=Alianza%20Estratégica%20HYDROVISION"
              class="inline-flex items-center gap-3 bg-gray-900 text-white font-semibold px-8 py-4 rounded-full hover:bg-gray-800 transition-colors"
            >
              <span>Proponer una alianza</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </ScrollReveal>

      </div>
    </section>

  </main>
</Layout>
