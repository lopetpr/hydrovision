---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";

import nosotrosHero from "@/assets/nosotros/nosotros-hero.webp";
import experienciaCampo from "@/assets/nosotros/experiencia-campo.webp";
import colaborador from "@/assets/nosotros/colaborador.webp";
---

<Layout
  title="Quiénes Somos | HYDROVISION"
  description="Somos HYDROVISION, una iniciativa que combina ingeniería, tecnología y conocimiento comunitario para resolver el acceso al agua en zonas altoandinas del Perú."
>
  <main class="w-full bg-white">
    <!-- PANTALLA 7: Quiénes Somos -->
    <section class="py-16 sm:py-20 lg:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
          class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-24 items-center"
        >
          <!-- Contenido -->
          <div>
            <p
              class="text-cyan-600 font-medium mb-4 tracking-wide uppercase text-xs sm:text-sm"
            >
              Quiénes somos
            </p>
            <h1
              class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold text-gray-900 leading-tight mb-6 lg:mb-8"
            >
              Somos
              <span class="text-gray-400">HYDROVISION</span>
            </h1>

            <div class="space-y-6 text-lg text-gray-600 leading-relaxed">
              <p>
                Somos una iniciativa que combina <strong class="text-gray-900"
                  >ingeniería, tecnología y conocimiento comunitario</strong
                > para resolver el acceso al agua en zonas altoandinas del Perú.
              </p>
              <p>
                Trabajamos directamente en campo, diseñando soluciones reales,
                económicas y sostenibles.
              </p>
            </div>
            <div class="mt-8 lg:mt-12 flex flex-wrap gap-6 sm:gap-8">
              <div>
                <p
                  class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900"
                >
                  100+
                </p>
                <p class="text-gray-400 text-xs sm:text-sm">
                  Familias beneficiadas
                </p>
              </div>
              <div>
                <p
                  class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900"
                >
                  5+
                </p>
                <p class="text-gray-400 text-xs sm:text-sm">
                  Años de experiencia
                </p>
              </div>
              <div>
                <p
                  class="text-2xl sm:text-3xl lg:text-4xl font-bold text-gray-900"
                >
                  Puno
                </p>
                <p class="text-gray-400 text-xs sm:text-sm">
                  Base de operaciones
                </p>
              </div>
            </div>
          </div>

          <!-- Imagen -->
          <div class="relative">
            <div class="aspect-[4/5] rounded-2xl bg-gray-100 overflow-hidden">
              <Image
                src={nosotrosHero}
                alt="Equipo HYDROVISION en campo"
                class="w-full h-full object-cover"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                loading="eager"
                quality="high"
              />
              <div
                class="hidden w-full h-full items-center justify-center bg-gradient-to-br from-cyan-50 to-blue-50"
              >
                <div class="text-center">
                  <span class="text-8xl">🏔️</span>
                  <p class="text-gray-400 mt-4 text-sm"></p>
                </div>
              </div>
            </div>

            <!-- Badge flotante -->
          </div>
        </div>
      </div>
    </section>

    <!-- Línea divisoria -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"
      >
      </div>
    </div>

    <!-- PANTALLA 8: Experiencia -->
    <section class="py-16 sm:py-20 lg:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-24">
          <!-- Imagen lado izquierdo -->
          <div class="order-2 lg:order-1">
            <div class="aspect-[4/3] rounded-2xl bg-gray-100 overflow-hidden">
              <Image
                src={experienciaCampo}
                alt="Trabajo en campo"
                class="w-full h-full object-cover"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                quality="high"
              />
              <div
                class="hidden w-full h-full items-center justify-center bg-gradient-to-br from-emerald-50 to-teal-50"
              >
                <div class="text-center">
                  <span class="text-8xl">🛠️</span>
                  <p class="text-gray-400 mt-4 text-sm">Foto de instalación</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Contenido lado derecho -->
          <div class="order-1 lg:order-2">
            <span
              class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl font-black text-gray-100 leading-none select-none"
              >02</span
            >

            <div class="mt-4 sm:mt-6">
              <h2
                class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-bold text-gray-900 mb-6 sm:mb-8"
              >
                Experiencia y validación en campo
              </h2>

              <ul class="space-y-6">
                <li class="flex items-start gap-4">
                  <div
                    class="w-10 h-10 rounded-full bg-cyan-50 flex items-center justify-center flex-shrink-0 mt-1"
                  >
                    <span class="text-cyan-600 font-bold">01</span>
                  </div>
                  <div>
                    <h3 class="text-lg font-bold text-gray-900">
                      Pilotos instalados en Queracucho
                    </h3>
                    <p class="text-gray-500 mt-1">
                      Proyectos funcionales validados con la comunidad
                    </p>
                  </div>
                </li>

                <li class="flex items-start gap-4">
                  <div
                    class="w-10 h-10 rounded-full bg-cyan-50 flex items-center justify-center flex-shrink-0 mt-1"
                  >
                    <span class="text-cyan-600 font-bold">02</span>
                  </div>
                  <div>
                    <h3 class="text-lg font-bold text-gray-900">
                      Experiencia en topografía y aprovechamiento hídrico
                    </h3>
                    <p class="text-gray-500 mt-1">
                      Levantamientos con drones y análisis técnico especializado
                    </p>
                  </div>
                </li>

                <li class="flex items-start gap-4">
                  <div
                    class="w-10 h-10 rounded-full bg-cyan-50 flex items-center justify-center flex-shrink-0 mt-1"
                  >
                    <span class="text-cyan-600 font-bold">03</span>
                  </div>
                  <div>
                    <h3 class="text-lg font-bold text-gray-900">
                      Validación con familias ganaderas
                    </h3>
                    <p class="text-gray-500 mt-1">
                      Soluciones probadas en condiciones reales del altiplano
                    </p>
                  </div>
                </li>

                <li class="flex items-start gap-4">
                  <div
                    class="w-10 h-10 rounded-full bg-cyan-50 flex items-center justify-center flex-shrink-0 mt-1"
                  >
                    <span class="text-cyan-600 font-bold">04</span>
                  </div>
                  <div>
                    <h3 class="text-lg font-bold text-gray-900">
                      Alianzas con organizaciones y empresas
                    </h3>
                    <p class="text-gray-500 mt-1">
                      Red de colaboradores comprometidos con el desarrollo rural
                    </p>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Línea divisoria -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"
      >
      </div>
    </div>

    <!-- PANTALLA 9: Equipo -->
    <section class="py-16 sm:py-20 lg:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="text-center mb-12 sm:mb-16 lg:mb-20">
          <p
            class="text-cyan-600 font-medium mb-4 tracking-wide uppercase text-xs sm:text-sm"
          >
            El equipo
          </p>
          <h2
            class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-bold text-gray-900"
          >
            Nuestro equipo
          </h2>
        </div>

        <!-- Miembro principal -->
        <div class="max-w-4xl mx-auto">
          <div
            class="grid grid-cols-1 md:grid-cols-3 gap-8 sm:gap-10 lg:gap-12 items-start"
          >
            <!-- Foto -->
            <div class="md:col-span-1">
              <div
                class="aspect-square rounded-2xl bg-gray-100 overflow-hidden"
              >
                <Image
                  src={colaborador}
                  alt="Fabio Raúl Lope Tapara"
                  class="w-full h-full object-cover"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                  loading="lazy"
                  quality="high"
                />
                <div
                  class="hidden w-full h-full items-center justify-center bg-gradient-to-br from-gray-100 to-gray-200"
                >
                  <div class="text-center">
                    <span class="text-6xl">👨‍💼</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Info -->
            <div class="md:col-span-2">
              <h3
                class="text-xl sm:text-2xl lg:text-3xl font-bold text-gray-900 mb-2"
              >
                Fabio Raúl Lope Tapara
              </h3>
              <p
                class="text-cyan-600 font-medium mb-4 sm:mb-6 text-sm sm:text-base"
              >
                Bachiller en Ingeniería Civil
              </p>

              <p
                class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3 sm:mb-4"
              >
                Especialista en
              </p>

              <ul class="space-y-3 text-gray-600 mb-8">
                <li class="flex items-center gap-3">
                  <span class="text-cyan-500">›</span>
                  <span>Drones y levantamiento topográfico</span>
                </li>
                <li class="flex items-center gap-3">
                  <span class="text-cyan-500">›</span>
                  <span>Sistemas de agua rural y altoandino</span>
                </li>
                <li class="flex items-center gap-3">
                  <span class="text-cyan-500">›</span>
                  <span>Modelación hidráulica</span>
                </li>
                <li class="flex items-center gap-3">
                  <span class="text-cyan-500">›</span>
                  <span>Gestión comunitaria</span>
                </li>
              </ul>
            </div>
          </div>

          <!-- Nota del equipo -->
          <div
            class="mt-10 sm:mt-12 lg:mt-16 p-6 sm:p-8 bg-gray-50 rounded-2xl text-center"
          >
            <span class="text-3xl sm:text-4xl mb-3 sm:mb-4 block">👥</span>
            <p class="text-base sm:text-lg text-gray-600">
              Equipo técnico y de campo con experiencia en zonas altoandinas.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="py-16 sm:py-20 lg:py-24 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2
          class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-bold text-gray-900 mb-3 sm:mb-4"
        >
          ¿Quieres trabajar con nosotros?
        </h2>
        <p class="text-base sm:text-lg lg:text-xl text-gray-500 mb-8 sm:mb-10">
          Estamos abiertos a colaboraciones, alianzas y nuevos proyectos
        </p>
        <a
          href="/contactanos"
          class="inline-flex items-center gap-2 sm:gap-3 bg-gray-900 text-white font-semibold px-6 sm:px-8 py-3 sm:py-4 rounded-full hover:bg-gray-800 transition-colors text-sm sm:text-base"
        >
          <span>Contáctanos</span>
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </section>
  </main>
</Layout>
